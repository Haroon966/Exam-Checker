{
  "expo": {
    "name": "Exam Checker",
    "slug": "exam-checker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of exam papers for OCR and grading.",
        "NSPhotoLibraryUsageDescription": "Select exam paper photos from your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D9488",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": ["CAMERA", "READ_MEDIA_IMAGES"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F0FDFA",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Exam Checker to use the camera to photograph exam papers."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Exam Checker to access photos of exam papers."
        }
      ],
      "expo-font"
    ]
  }
}
